#!/usr/bin/env bash

# gopm - Go Project Manager
# Shell wrapper that locates and sources the core logic, then dispatches.
#
# This single wrapper works across every install layout:
#   - flat release tarball : binary + core sit beside this script
#   - FHS install (AUR/deb/rpm/brew) : wrapper in bin/, core in share/gopm/
#   - development checkout : run ./packaging/gopm from the repo root
# GOPM_CORE / GOPM_BINARY env vars override the lookups entirely.

set -e

# Resolve this script's real directory, following symlinks. This matters for
# Homebrew casks and `ln -s` tarball installs, where `gopm` is a symlink in a
# bin/ dir but gopm-core.sh + gopm-bin live in the real (staging) directory.
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

# Locate gopm-core.sh across the supported layouts.
find_gopm_core() {
    local candidates=(
        "$GOPM_CORE"
        "$SCRIPT_DIR/gopm-core.sh"                 # flat tarball
        "$SCRIPT_DIR/../gopm-core.sh"              # dev: packaging/ -> repo root
        "$SCRIPT_DIR/../share/gopm/gopm-core.sh"   # FHS: bin/ -> share/gopm/
        "/usr/share/gopm/gopm-core.sh"
        "/usr/local/share/gopm/gopm-core.sh"
    )
    local candidate
    for candidate in "${candidates[@]}"; do
        if [ -n "$candidate" ] && [ -f "$candidate" ]; then
            echo "$candidate"
            return 0
        fi
    done
    return 1
}

GOPM_CORE_PATH=$(find_gopm_core)
if [ -z "$GOPM_CORE_PATH" ]; then
    echo "Error: gopm-core.sh not found (looked beside the wrapper and in share/gopm)." >&2
    echo "Set GOPM_CORE to its path to override." >&2
    exit 1
fi
source "$GOPM_CORE_PATH"

# Locate the gopm-bin binary across the supported layouts.
find_gopm_binary() {
    if [ -n "$GOPM_BINARY" ] && [ -f "$GOPM_BINARY" ] && [ -x "$GOPM_BINARY" ]; then
        echo "$GOPM_BINARY"
        return 0
    fi

    local candidates=(
        "$SCRIPT_DIR/gopm-bin"           # flat tarball
        "$SCRIPT_DIR/../gopm-bin"        # dev: packaging/ -> repo root
        "$(command -v gopm-bin 2>/dev/null)" # on PATH
        "$HOME/.local/bin/gopm-bin"      # user local bin
        "/usr/bin/gopm-bin"              # FHS system install (deb/rpm/AUR)
        "/usr/local/bin/gopm-bin"        # system local bin
    )

    local candidate
    for candidate in "${candidates[@]}"; do
        if [ -n "$candidate" ] && [ -f "$candidate" ] && [ -x "$candidate" ]; then
            echo "$candidate"
            return 0
        fi
    done

    return 1
}

GOPM_BINARY=$(find_gopm_binary)
if [ -z "$GOPM_BINARY" ]; then
    print_error "gopm binary not found."
    echo "Please ensure gopm is installed or gopm-bin is in your PATH."
    echo "If you're in development, run: go build -o gopm-bin ./cmd/gopm"
    exit 1
fi
export GOPM_BINARY

# Dispatch to the core entry point.
gopm_main "$@"
