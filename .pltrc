# paleta configuration file
# Generated by 'plt init'. Edit freely or re-run 'plt init' to update.
frecency:
    enabled: true
    recency_weight: 50
    frequency_weight: 50
locations:
    - name: root
      location: .
      type: go
      commands:
        - name: build
          command: go build ./...
        - name: build binary
          command: go build -o plt-bin ./cmd/plt/...
        - name: test all
          command: go test ./...
        - name: test verbose
          command: go test -v ./...
        - name: test ui
          command: go test -v ./internal/ui/...
        - name: test commands
          command: go test -v ./internal/commands/...
        - name: test config
          command: go test -v ./internal/config/...
        - name: test history
          command: go test -v ./internal/history/...
        - name: run help
          command: go run ./cmd/plt/... help
        - name: run list
          command: go run ./cmd/plt/... list
        - name: run select tui
          command: go run ./cmd/plt/... select --tui
        - name: run select
          command: go run ./cmd/plt/... select
        - name: fmt
          command: go fmt ./...
        - name: vet
          command: go vet ./...
        - name: tidy
          command: go mod tidy
        - name: something
          command:
            - '@root:test ui'
            - '@root:tidy'
            - '@root:fmt'
            - '@root[go]:fmt'
      focused: true
