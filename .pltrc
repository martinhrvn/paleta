# paleta configuration file
# Generated by 'plt init'. Edit freely or re-run 'plt init' to update.
frecency:
    enabled: true
    recency_weight: 50
    frequency_weight: 50
locations:
    - name: root
      location: .
      type: go
      commands:
        - name: build
          command: go build ./...
        - name: build_binary
          command: go build -o plt-bin ./cmd/plt/...
        - name: test_all
          command: go test ./...
        - name: test_verbose
          command: go test -v ./...
        - name: test_ui
          command: go test -v ./internal/ui/...
        - name: test_commands
          command: go test -v ./internal/commands/...
        - name: test_config
          command: go test -v ./internal/config/...
        - name: test_history
          command: go test -v ./internal/history/...
        - name: run_help
          command: go run ./cmd/plt/... help
        - name: run_list
          command: go run ./cmd/plt/... list
        - name: run_select_tui
          command: go run ./cmd/plt/... select --tui
        - name: run_select
          command: go run ./cmd/plt/... select
        - name: fmt
          command: go fmt ./...
        - name: vet
          command: go vet ./...
        - name: tidy
          command: go mod tidy
        - name: format
          command:
            - go fmt ./...
            - '@root[go]:fmt'
      focused: true
